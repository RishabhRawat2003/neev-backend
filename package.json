    "scripts": {
        "start": "cross-env BABEL_DISABLE_CACHE=1 NODE_ENV=development nodemon neev.js",
        "build": "npm run build:server",
        "build:server": "cross-env NODE_ENV=production babel --delete-dir-on-start --out-dir dist --copy-files --ignore \\\\\\\"**/__tests__/**,**/__mocks__/**\\\\\\\" --no-copy-ignored src",
        "start:prod": "cross-env NODE_ENV=production node neev.js",
        "build:all": "npm run clean && npm run build:server",
        "clean": "rimraf dist",
        "slate": "rimraf node_modules && npm install",
        "lint": "eslint server"
    },
    "dependencies": {
        "axios": "^1.6.8",
        "bcrypt": "^5.1.1",
        "bcrypt-nodejs": "^0.0.3",
        "bcryptjs": "^2.4.3",
        "bluebird": "^3.5.1",
        "body-parser": "^1.15.1",
        "chalk": "^3.0.0",
        "cloudinary": "^1.41.3",
        "compression": "^1.7.4",
        "cookie-parser": "^1.4.3",
        "cors": "^2.8.5",
        "cross-env": "^1.0.8",
        "dotenv": "^8.2.0",
        "express": "^4.16.3",
        "express-session": "^1.18.1",
        "jsonwebtoken": "^8.5.1",
        "jwt-decode": "^4.0.0",
        "lodash": "^4.17.21",
        "lru-cache": "^11.2.2",
        "moment": "^2.22.2",
        "moment-timezone": "^0.5.47",
        "mongoose": "^8.6.1",
