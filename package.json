        "node-cron": "^3.0.3",
        "nodemailer": "^6.7.2",
        "replaceall": "^0.1.6",
        "resend": "^6.10.0",
        "throng": "^4.0.0",
        "uuid": "^11.0.5",
        "validator": "^13.7.0"
    },
    "devDependencies": {
        "@babel/cli": "^7.20.7",
        "@babel/core": "^7.20.12",
        "@babel/preset-env": "^7.20.2",
        "@babel/register": "^7.25.9",
        "jest": "^30.0.4",
        "nodemon": "^1.19.4",
        "supertest": "^7.1.3"
